<+>/* =============================================================================\r\n   SECTION 1: THEME VARIABLE DEFINITIONS\r\n   ============================================================================= */\r\n\r\n:root,\r\n[data-md-color-scheme=\"default\"] {\r\n    /* Page & Container */\r\n    --quiz-bg-page: var(--md-code-bg-color, #f8f9fb00);\r\n    --quiz-bg-main: var(--md-default-bg-color, #ffffff);\r\n    /* Adding a default value here ensures buttons aren't transparent in basic themes */\r\n    --quiz-bg-card: var(--md-default-bg-color--light, #ffffff);\r\n\r\n    /* Typography */\r\n    --quiz-text-title: var(--md-primary-fg-color, #3066ae);\r\n    --quiz-text-desc: var(--md-primary-fg-color, #1976d2);\r\n    --quiz-text-question: var(--md-typeset-color, #000000);\r\n    --quiz-text-body: var(--md-typeset-color, #000000);\r\n    --quiz-text-timer: var(--md-typeset-color, #000000);\r\n    --quiz-text-status: var(--md-primary-fg-color, #42a5f5);\r\n\r\n    /* Interactive & Feedback */\r\n    --quiz-text-interactive: var(--md-accent-fg-color, #007acc);\r\n    --quiz-border: var(--md-primary-fg-color--light, #64b5f6);\r\n    --quiz-btn-primary: var(--md-primary-fg-color, #2196f3);\r\n    --quiz-btn-shadow: var(--md-primary-fg-color--dark, #244f80);\r\n    --quiz-feedback-incorrect-background: #f8d7da;\r\n    /* Progress & Meta */\r\n    --quiz-bg-meta: var(--md-code-bg-color, #e6edf5);\r\n    --quiz-text-meta: var(--md-primary-fg-color, #2f6fb2);\r\n    --quiz-progress-bg: var(--md-code-bg-color, #f8f9fb);\r\n    --quiz-progress-fill: var(--md-primary-fg-color, #2b68b4);\r\n\r\n    --quiz-shadow: color-mix(in srgb, var(--md-primary-fg-color), transparent 40%);\r\n    --quiz-bg-report-card: var(--md-default-bg-color, #ffffff);\r\n\r\n    --quiz-nav-bg: var(--md-primary-fg-color--dark, #1a4a8d);\r\n    --quiz-nav-border: var(--md-primary-fg-color--dark, #153e77);\r\n    --quiz-report-correct: #28a745;\r\n    --quiz-report-incorrect: #dc3545;\r\n}\r\n\r\n/* Dark Mode Overrides - Slate */\r\n[data-md-color-scheme=\"slate\"] {\r\n    /* Page & Container */\r\n    --quiz-bg-page: var(--md-code-bg-color, #18171d);\r\n    --quiz-bg-main: var(--md-default-bg-color, #24242e);\r\n    --quiz-bg-card: var(--md-default-bg-color--light, #2e303e);\r\n\r\n    /* Typography */\r\n    --quiz-text-title: var(--md-primary-fg-color--light, #93b9ef);\r\n    --quiz-text-desc: var(--md-typeset-color, #e2e2e2);\r\n    --quiz-text-question: var(--md-typeset-color, #f8f9fa);\r\n    --quiz-text-interactive: var(--md-accent-fg-color, #93b9ef);\r\n    --quiz-text-status: var(--md-primary-fg-color--light, #93b9ef);\r\n    --quiz-text-timer: var(--quiz-text-status);\r\n    --quiz-dropdown-text: #ffffff;\r\n    --quiz-text-body: #f8f9fa;\r\n\r\n    /* Interactive & Feedback */\r\n    --quiz-border: var(--md-primary-fg-color--light, #5a6b89);\r\n    --quiz-btn-primary: var(--md-primary-fg-color, #3b82f6);\r\n    --quiz-btn-shadow: rgba(0, 0, 0, 0.4);\r\n    --quiz-nav-bg: var(--md-primary-fg-color, #3b82f6);\r\n    --quiz-nav-border: var(--md-primary-fg-color--light, #5a6b89);\r\n    --quiz-feedback-incorrect-background: #f8d7da;\r\n\r\n    /* Progress & Meta */\r\n    --quiz-bg-meta: var(--md-code-bg-color, #3d4051);\r\n    --quiz-text-meta: var(--md-primary-fg-color--light, #d1d9e6);\r\n    --quiz-progress-bg: var(--md-code-bg-color, #3d4051);\r\n    --quiz-progress-fill: var(--md-primary-fg-color, #3b82f6);\r\n\r\n    --quiz-shadow: color-mix(in srgb, var(--md-primary-fg-color), transparent 40%);\r\n    --quiz-bg-report-card: var(--md-default-bg-color, #24242e);\r\n    --quiz-bg-main: #24242e;\r\n\r\n    --quiz-report-correct: #81c784;\r\n    --quiz-report-incorrect: #e57373;\r\n}\r\n\r\n/* =============================================================================\r\n   2. BASE LAYOUT & CONTAINERS\r\n   ============================================================================= */\r\n\r\n/* Card */\r\n.quiz-start-screen {\r\n    background: var(--quiz-bg-card);\r\n    width: 90%;\r\n    max-width: 600px;\r\n    padding: 3em 3em;\r\n    border-radius: 18px;\r\n    box-shadow: 0 4px 8px var(--quiz-shadow);\r\n    text-align: center;\r\n    margin: 50px auto;\r\n}\r\n\r\n/* Metadata pills */\r\n.quiz-meta-info {\r\n    display: flex;\r\n    justify-content: center;\r\n    gap: 1.25rem;\r\n    margin-bottom: 2.5rem;\r\n    flex-wrap: wrap;\r\n}\r\n\r\n.quiz-meta-item {\r\n    font-size: 0.9rem;\r\n    color: var(--quiz-text-meta);\r\n    background: var(--quiz-bg-meta);\r\n    padding: 0.45rem 1rem;\r\n    border-radius: 999px;\r\n    font-weight: 500;\r\n}\r\n\r\n/* quiz container */\r\n.quiz-container {\r\n    font-family: \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\r\n    background-color: transparent;\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n    width: 100%;\r\n    max-width: 100%;\r\n    box-sizing: border-box;\r\n    padding: 10px;\r\n    margin: 0 auto;\r\n}\r\n\r\n/* quiz question container */\r\n.quiz-question-block {\r\n    background-color: transparent;\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: center;\r\n    margin-bottom: 20px;\r\n}\r\n\r\n.quiz-answer-container {\r\n    display: flex;\r\n    flex-direction: row;\r\n    flex-wrap: wrap;\r\n    justify-content: center;\r\n    align-items: center;\r\n    gap: 15px;\r\n    width: fit-content;\r\n    max-width: 95%;\r\n    margin: 0 auto 20px auto;\r\n}\r\n\r\n\r\n.quiz-main-wrapper {\r\n    position: relative;\r\n    width: 90%;\r\n    max-width: 800px;\r\n    margin: 50px auto;\r\n    padding: 0 !important;\r\n    padding-bottom: 20px !important;\r\n    border-radius: 12px;\r\n    overflow: clip;\r\n    background-color: var(--quiz-bg-main);\r\n    box-shadow: 0 4px 12px var(--quiz-shadow);\r\n    border-radius: 12px;\r\n    box-shadow: 0 4px 8px var(--quiz-shadow);\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: center;\r\n}\r\n\r\n.quiz-container.quiz-results-shown .quiz-main-wrapper {\r\n    overflow: visible !important;\r\n    padding-bottom: 20px !important;\r\n}\r\n\r\n.quiz-question-block {\r\n    width: 100%;\r\n    padding: 0 20px;\r\n    box-sizing: border-box;\r\n}\r\n\r\n.quiz-question {\r\n    font-family: \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\r\n    color: var(--quiz-text-question);\r\n    text-align: center;\r\n    font-size: 1.4rem;\r\n    line-height: 1.4;\r\n    margin: 30px 0;\r\n}\r\n\r\n.quiz-retake-container {\r\n    width: 100%;\r\n    text-align: center;\r\n    margin-top: 20px;\r\n    display: block !important;\r\n}\r\n\r\n/* =============================================================================\r\n   3. TYPOGRAPHY & TITLES\r\n   ============================================================================= */\r\n\r\n.quiz-feedback-msg {\r\n    margin-top: 15px;\r\n    padding: 10px;\r\n    border-radius: 5px;\r\n}\r\n\r\n.quiz-title {\r\n    font-size: 1.8rem;\r\n    font-weight: 700;\r\n    color: var(--quiz-text-title);\r\n    margin-bottom: 1rem;\r\n    padding: 0 20px;\r\n}\r\n\r\n.quiz-description {\r\n    text-align: center;\r\n    margin-bottom: 2rem;\r\n    display: block;\r\n}\r\n\r\n.custom-quiz-desc {\r\n    color: var(--quiz-text-desc);\r\n    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;\r\n    font-size: 1.0rem;\r\n    font-weight: 350;\r\n    text-align: center;\r\n    display: block;\r\n}\r\n\r\n/* =============================================================================\r\n   4. INTERACTIVE ELEMENTS (Answers, Items, Buttons)\r\n   ============================================================================= */\r\n\r\n/* Start button */\r\n.quiz-btn-start {\r\n    background: var(--quiz-btn-primary);\r\n    color: #ffffff;\r\n    font-size: 1.05rem;\r\n    font-weight: 600;\r\n    padding: 0.8rem 3rem;\r\n    border: none;\r\n    border-radius: 999px;\r\n    cursor: pointer;\r\n    box-shadow: 0 6px 0 var(--quiz-btn-shadow);\r\n    transition: all 0.15s ease;\r\n    margin-bottom: 1cm;\r\n}\r\n\r\n.quiz-btn-start:hover {\r\n    background-color: var(--quiz-btn-primary);\r\n    border-color: var(--quiz-btn-primary);\r\n    color: #ffffff;\r\n}\r\n\r\n.quiz-btn-start:active {\r\n    transform: translateY(2px);\r\n    box-shadow: 0 4px 0 var(--quiz-btn-shadow);\r\n}\r\n\r\n/* answer buttons */\r\n.quiz-answer,\r\n.quiz-order-item,\r\n.quiz-match-item,\r\n.quiz-match-pair {\r\n    margin: 5px;\r\n    padding: 8px 16px;\r\n    border: 1px solid var(--quiz-text-interactive);\r\n    border-radius: 8px;\r\n    background: var(--quiz-bg-card);\r\n    color: var(--quiz-text-interactive);\r\n    cursor: pointer;\r\n    font-family: inherit;\r\n    font-size: 16px;\r\n    text-align: center;\r\n    box-sizing: border-box;\r\n    min-width: 120px;\r\n    max-width: 100%;\r\n    transition: all 0.2s ease;\r\n}\r\n\r\n.quiz-answer {\r\n    display: block !important;\r\n    text-align: center;\r\n    line-height: 1.4;\r\n    padding: 12px 16px !important;\r\n    word-wrap: break-word;\r\n}\r\n\r\n.quiz-answer:not([style*=\"width\"]) {\r\n    min-width: 150px;\r\n}\r\n\r\n/* darker blue on hover */\r\n.quiz-answer:hover,\r\n.quiz-order-item:hover,\r\n.quiz-match-item:hover,\r\n.quiz-match-pair:hover,\r\n.quiz-dropdown:hover {\r\n    background-color: var(--quiz-text-interactive) !important;\r\n    border-color: var(--quiz-text-interactive) !important;\r\n    color: #ffffff !important;\r\n}\r\n\r\n.quiz-answer.selected,\r\n.quiz-match-item.selected {\r\n    background-color: var(--quiz-text-interactive);\r\n    border-color: var(--quiz-text-interactive);\r\n    color: #ffffff !important;\r\n}\r\n\r\n.quiz-answer.correct {\r\n    background-color: #28a745;\r\n    color: white;\r\n    border: 2px solid #1e7e34;\r\n}\r\n\r\n.quiz-answer.incorrect {\r\n    background-color: #dc3545;\r\n    color: white;\r\n    border: 2px solid #b02a37;\r\n}\r\n\r\n.quiz-answer.shouldbecorrect {\r\n    border: 2px solid green;\r\n}\r\n\r\n/* dropdown container */\r\n.quiz-dropdown {\r\n    background-color: var(--quiz-bg-card);\r\n    color: var(--quiz-text-interactive);\r\n    border: 1px solid var(--quiz-text-interactive);\r\n    border-radius: 8px;\r\n    font-size: 16px;\r\n    font-family: inherit;\r\n    padding: 8px 16px;\r\n    vertical-align: middle;\r\n    cursor: pointer;\r\n    transition: all 0.2s ease;\r\n\r\n    text-overflow: ellipsis;\r\n    white-space: nowrap;\r\n    overflow: hidden;\r\n    max-width: 100%;\r\n    max-height: 80px;\r\n    width: auto;\r\n    height: auto;\r\n}\r\n\r\n.quiz-dropdown:hover {\r\n    background-color: var(--quiz-text-interactive) !important;\r\n    border-color: var(--quiz-text-interactive) !important;\r\n    color: #ffffff !important;\r\n}\r\n\r\n.quiz-dropdown option {\r\n    background-color: var(--quiz-bg-main);\r\n    color: var(--quiz-text-body);\r\n    font-size: 16px;\r\n}\r\n\r\n/* --- Ordering List Container --- */\r\n.quiz-ordering-list {\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: 12px;\r\n    max-width: 600px;\r\n    margin: 0 auto 20px auto;\r\n    padding: 0;\r\n    list-style: none;\r\n}\r\n\r\n/* --- Ordering Item (Draggable) --- */\r\n.quiz-order-item {\r\n    padding: 8px 16px;\r\n    border: 1px solid var(--quiz-text-interactive);\r\n    border-radius: 8px;\r\n    cursor: grab;\r\n    user-select: none;\r\n    font-family: inherit;\r\n    font-size: 16px;\r\n    color: var(--quiz-text-interactive);\r\n    text-align: center;\r\n    box-sizing: border-box;\r\n    min-width: 120px;\r\n    max-width: 100%;\r\n    transition: background 0.2s, border-color 0.2s;\r\n}\r\n\r\n/* Matching question styling */\r\n.quiz-matching-container {\r\n    display: grid;\r\n    grid-template-columns: 1fr 1fr;\r\n    gap: 20px;\r\n    width: 100%;\r\n}\r\n\r\n.quiz-match-item,\r\n.quiz-match-pair {\r\n    margin: 5px;\r\n    padding: 8px 16px;\r\n    border: 1px solid var(--quiz-text-interactive);\r\n    border-radius: 8px;\r\n    color: var(--quiz-text-interactive);\r\n    cursor: pointer;\r\n    font-family: inherit;\r\n    font-size: 16px;\r\n    text-align: center;\r\n    box-sizing: border-box;\r\n    min-width: 120px;\r\n    max-width: 100%;\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: 12px;\r\n}\r\n\r\n.quiz-match-left,\r\n.quiz-match-right {\r\n    display: grid;\r\n    grid-auto-rows: 1fr;\r\n    gap: 12px;\r\n}\r\n\r\n.quiz-match-item {\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n    text-align: center;\r\n    padding: 12px 15px !important;\r\n    box-sizing: border-box !important;\r\n    height: 100%;\r\n    width: 100%;\r\n    margin: 0;\r\n    overflow-wrap: anywhere;\r\n    word-break: break-word;\r\n    line-height: 1.2;\r\n}\r\n\r\n.quiz-match-item:hover,\r\n.quiz-match-pair:hover {\r\n    background-color: var(--quiz-text-interactive) !important;\r\n    border-color: var(--quiz-text-interactive) !important;\r\n    color: #ffffff !important;\r\n}\r\n\r\n.quiz-match-item.selected {\r\n    background-color: var(--quiz-text-interactive) !important;\r\n    border-color: var(--quiz-text-interactive) !important;\r\n    color: #ffffff !important;\r\n}\r\n\r\n.quiz-match-pair.correct {\r\n    background-color: #28a745;\r\n    color: white;\r\n    border: 2px solid #1e7e34;\r\n}\r\n\r\n.quiz-match-pair.incorrect {\r\n    background-color: #dc3545;\r\n    color: white;\r\n    border: 2px solid #b02a37;\r\n}\r\n\r\n.quiz-match-solved-area {\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: center;\r\n    gap: 10px;\r\n    margin-top: 20px;\r\n}\r\n\r\n.quiz-order-item:hover {\r\n    background-color: var(--quiz-text-interactive) !important;\r\n    border-color: var(--quiz-text-interactive) !important;\r\n    color: #ffffff !important;\r\n}\r\n\r\n.ordering-ghost {\r\n    opacity: 0.5;\r\n    background-color: var(--quiz-text-interactive) !important;\r\n    border-color: var(--quiz-text-interactive) !important;\r\n}\r\n\r\n.sortable-chosen {\r\n    cursor: grabbing !important;\r\n}\r\n\r\n/* check button */\r\n.quiz-btn-check-answer {\r\n    align-self: flex-end;\r\n    margin-top: 20px;\r\n    margin-left: auto;\r\n    margin-right: 0;\r\n    width: fit-content;\r\n    min-width: 150px;\r\n    padding: 10px 20px;\r\n    background-color: var(--quiz-btn-primary);\r\n    color: white;\r\n    border: none;\r\n    border-radius: 8px;\r\n    font-size: 15px;\r\n    font-weight: bold;\r\n    cursor: pointer;\r\n}\r\n\r\n.quiz-btn-retake {\r\n    background-color: var(--quiz-btn-primary);\r\n    color: white;\r\n    padding: 10px 25px;\r\n    border-radius: 999px;\r\n    border: none;\r\n    font-weight: bold;\r\n    cursor: pointer;\r\n    display: inline-block;\r\n    margin: 5px 10px;\r\n}\r\n\r\n.quiz-btn-retake:hover {\r\n    background-color: var(--quiz-btn-shadow);\r\n    border-color: var(--quiz-btn-shadow);\r\n    color: #ffffff;\r\n}\r\n\r\n.quiz-order-item img {\r\n    height: 120px;\r\n    width: auto;\r\n    max-width: 100%;\r\n    display: block;\r\n    margin: 0 auto 8px;\r\n    object-fit: contain;\r\n    border-radius: 8px;\r\n}\r\n\r\n/* =============================================================================\r\n   5. NAVIGATION & PROGRESS\r\n   ============================================================================= */\r\n\r\n.quiz-nav-next,\r\n.quiz-nav-previous,\r\n.quiz-nav-submit {\r\n    background-color: var(--quiz-nav-bg);\r\n    border: 2px solid var(--quiz-nav-border);\r\n    color: #ffffff;\r\n    border-radius: 8px;\r\n    font-family: \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\r\n    font-weight: bold;\r\n    cursor: pointer;\r\n    padding: 8px 16px;\r\n    font-size: 16px;\r\n    margin: 10px 0;\r\n    display: inline-block;\r\n    text-align: center;\r\n    box-sizing: border-box;\r\n    min-width: 120px;\r\n    max-width: 100%;\r\n    transition: background 0.2s ease;\r\n}\r\n\r\n.quiz-nav-submit {\r\n    background-color: #28a745;\r\n    border: 2px solid #1e7e34;\r\n}\r\n\r\n.quiz-nav-submit:hover {\r\n    background-color: #1e7e34;\r\n    border-color: #155724;\r\n}\r\n\r\n.quiz-nav-next:hover,\r\n.quiz-nav-previous:hover {\r\n    filter: brightness(1.2);\r\n    background-color: var(--quiz-nav-bg);\r\n}\r\n\r\n.quiz-navigation {\r\n    display: flex;\r\n    justify-content: center;\r\n    align-items: center;\r\n    gap: 12px;\r\n    margin-top: 20px;\r\n    flex-wrap: wrap;\r\n}\r\n\r\n.quiz-header {\r\n    position: sticky;\r\n    z-index: 100;\r\n    top: calc(var(--md-header-height, 48px) - 1px);\r\n    background-color: var(--quiz-bg-meta);\r\n    border-bottom: 1px solid var(--quiz-border);\r\n    box-shadow: 0 4px 6px -4px rgba(0, 0, 0, 0.05);\r\n    width: 100%;\r\n    height: 52px;\r\n    display: flex;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    padding: 0 24px;\r\n    box-sizing: border-box;\r\n    transition: all 0.2s ease;\r\n    align-self: stretch;\r\n}\r\n\r\n.invisible-header {\r\n    display: none !important;\r\n}\r\n\r\n.quiz-timer-display {\r\n    position: relative;\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 8px;\r\n    font-weight: 700;\r\n    font-size: 0.9rem;\r\n    color: var(--quiz-text-title);\r\n    font-variant-numeric: tabular-nums;\r\n}\r\n\r\n.quiz-timer-display::before {\r\n    content: \"⏱\";\r\n    font-size: 1.1rem;\r\n    opacity: 0.8;\r\n}\r\n\r\n.quiz-status-text {\r\n    align-items: center;\r\n    font-weight: 600;\r\n    font-size: 0.85rem;\r\n    color: var(--quiz-text-meta);\r\n}\r\n\r\n.quiz-progress-container {\r\n    position: absolute;\r\n    bottom: 0;\r\n    left: 0;\r\n    width: 100%;\r\n    height: 4px;\r\n    background-color: var(--quiz-bg-meta);\r\n    margin: 0;\r\n    border-radius: 0;\r\n}\r\n\r\n.quiz-progress-bar {\r\n    height: 100%;\r\n    background-color: var(--quiz-btn-primary);\r\n    transition: width 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);\r\n    border-radius: 0 2px 2px 0;\r\n}\r\n\r\n/* =============================================================================\r\n   6. RESULTS & REPORTS\r\n    ============================================================================= */\r\n\r\n.quiz-container.quiz-results-shown .quiz-header {\r\n    display: none !important;\r\n}\r\n\r\n.quiz-results {\r\n    scroll-margin-top: 100px;\r\n}\r\n\r\n.quiz-results,\r\n.quiz-report-card,\r\n.quiz-results-container {\r\n    background-color: var(--quiz-bg-main) !important;\r\n    color: var(--quiz-text-body);\r\n}\r\n\r\n.quiz-results .result-item,\r\n.quiz-results div[style*=\"background\"] {\r\n    background-color: var(--quiz-bg-card) !important;\r\n    color: var(--quiz-text-body) !important;\r\n    border: 1px solid var(--quiz-border);\r\n}\r\n\r\n.report-order-item img,\r\n.report-answer-item img {\r\n    width: 80px;\r\n    height: 80px;\r\n    object-fit: contain;\r\n    margin: 5px;\r\n    vertical-align: middle;\r\n    display: inline-block;\r\n}\r\n\r\n.quiz-explanation-box {\r\n    margin-top: 15px;\r\n    padding: 12px;\r\n    background-color: var(--quiz-bg-meta);\r\n    border-left: 4px solid var(--quiz-btn-primary);\r\n    border-radius: 4px;\r\n}\r\n\r\n.quiz-explanation-title {\r\n    color: var(--quiz-text-title);\r\n    display: block;\r\n    margin-bottom: 8px;\r\n}\r\n\r\n.quiz-explanation-content {\r\n    color: var(--quiz-text-body);\r\n}\r\n\r\n/* =============================================================================\r\n   7. UTILITIES & MATHJAX FIXES\r\n   ============================================================================= */\r\n\r\n.quiz-container.timer-warning {\r\n    border: 3px solid red !important;\r\n}\r\n\r\n.quiz-container.timer-warning #time-display {\r\n    color: red !important;\r\n    font-weight: bold !important;\r\n}\r\n\r\n.quiz-container.timer-warning .quiz-timer-display {\r\n    color: red !important;\r\n    font-weight: bold !important;\r\n}\r\n\r\n/* responsiveness adjustments */\r\n@media (max-width: 480px) {\r\n    .quiz-header {\r\n        height: 48px;\r\n        padding: 0 16px;\r\n        top: calc(var(--md-header-height, 48px) - 1px);\r\n    }\r\n\r\n    .quiz-start-screen {\r\n        padding: 2rem 1.5rem 2.5rem;\r\n    }\r\n\r\n    .quiz-title {\r\n        font-size: 1.6rem;\r\n    }\r\n\r\n    .quiz-answer {\r\n        width: auto;\r\n        max-width: 90%;\r\n        margin: 5px auto;\r\n    }\r\n\r\n    /* navigation buttons stacked */\r\n    .quiz-navigation {\r\n        flex-direction: column;\r\n        align-items: center;\r\n        gap: 8px;\r\n    }\r\n\r\n    .quiz-navigation button {\r\n        width: auto;\r\n        max-width: 90%;\r\n        margin: 5px 0;\r\n        min-width: 120px;\r\n    }\r\n\r\n    .quiz-matching-container {\r\n        grid-template-columns: 1fr;\r\n        gap: 15px;\r\n    }\r\n\r\n    .quiz-match-left,\r\n    .quiz-match-right {\r\n        grid-auto-rows: 1fr;\r\n        width: 100%;\r\n    }\r\n\r\n    .quiz-match-left {\r\n        margin-bottom: 10px;\r\n    }\r\n\r\n    .quiz-match-item {\r\n        width: 100%;\r\n        box-sizing: border-box;\r\n    }\r\n}\r\n\r\n.quiz-answer mjx-container,\r\n.quiz-match-item mjx-container,\r\n.quiz-order-item mjx-container {\r\n    margin: 5px 0;\r\n    display: inline-block;\r\n    max-width: none;\r\n    overflow-x: visible;\r\n    vertical-align: middle;\r\n}\r\n\r\n.quiz-answer mjx-container {\r\n    display: inline;\r\n    vertical-align: baseline;\r\n    margin: 0 2px;\r\n    white-space: nowrap;\r\n}\r\n\r\n.quiz-review-list div,\r\n.quiz-review-list span,\r\n.quiz-review-list p {\r\n    word-break: normal;\r\n    overflow-wrap: anywhere;\r\n    white-space: normal;\r\n}\r\n\r\n.quiz-review-list>div {\r\n    max-width: 100%;\r\n    box-sizing: border-box;\r\n    overflow: hidden;\r\n}
